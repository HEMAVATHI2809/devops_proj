# Copy to .env on the deployment server next to docker-compose.yml (never commit real .env).

# Strong secret for JWT (override docker-compose default in production)
# JWT_SECRET=your-long-random-secret-at-least-32-chars

# Docker Hub namespaces (must match images built in CI)
FRONTEND_IMAGE=your-dockerhub-username/appointment-scheduler-frontend
BACKEND_IMAGE=your-dockerhub-username/appointment-scheduler-backend

# Host port published for the SPA (nginx serves on container port 80)
FRONTEND_PORT=3001

# Browser origin(s) allowed by the API (comma-separated)
FRONTEND_URL=http://YOUR_SERVER:3001
FRONTEND_URLS=http://YOUR_SERVER:3001

# Optional override (defaults work with bundled mongo service)
# MONGO_URI=mongodb://mongo:27017/appointments

# IMAGE_TAG is normally injected by CI (commit SHA); omit to use :latest locally.
